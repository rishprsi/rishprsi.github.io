---
const { group } = Astro.props;
const flagship = group.projects[0];
const rest = group.projects.slice(1);
---

<section class="panel group reveal">
  <div class="group-head">
    <div class="group-head-text">
      <h3 class="group-domain">{group.domain}</h3>
      <p class="group-blurb">{group.blurb}</p>
    </div>
    <div class="chips group-chips">
      {group.expertise.map((s) => <span class="chip">{s}</span>)}
    </div>
  </div>

  <div class="g-featured">
    <div class="card-canvas-wrap">
      <canvas data-anim={flagship.anim}></canvas>
      <span class="card-tag">{flagship.tag}</span>
    </div>
    <div class="card-body">
      <span class="flagship-label mono">★ flagship mission</span>
      <h4>{flagship.name}</h4>
      <p class="card-desc">{flagship.desc}</p>
      <div class="card-tech">{flagship.tech.map((t) => <span>{t}</span>)}</div>
      {
        flagship.links && flagship.links.length > 0 && (
          <div class="card-links">
            {flagship.links.map((l) => (
              <a href={l.url} target="_blank" rel="noopener">{l.label}</a>
            ))}
          </div>
        )
      }
      {flagship.note && <p class="card-note">{flagship.note}</p>}
    </div>
  </div>

  {
    rest.length > 0 && (
      <>
        <button class="group-toggle mono" aria-expanded="false" data-count={rest.length}>
          ▸ open full mission log <span class="toggle-count">(+{rest.length})</span>
        </button>
        <div class="group-more-wrap">
          <div class="group-more">
            {rest.map((p) => (
              <article class="panel card sub-card">
                <div class="card-canvas-wrap">
                  <canvas data-anim={p.anim}></canvas>
                  <span class="card-tag">{p.tag}</span>
                </div>
                <div class="card-body">
                  <h4>{p.name}</h4>
                  <p class="card-desc">{p.desc}</p>
                  <div class="card-tech">{p.tech.map((t) => <span>{t}</span>)}</div>
                  {p.links && p.links.length > 0 && (
                    <div class="card-links">
                      {p.links.map((l) => (
                        <a href={l.url} target="_blank" rel="noopener">{l.label}</a>
                      ))}
                    </div>
                  )}
                  {p.note && <p class="card-note">{p.note}</p>}
                </div>
              </article>
            ))}
          </div>
        </div>
      </>
    )
  }
</section>
