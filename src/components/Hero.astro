---
import { SITE } from "../data.js";

const resumeHref = import.meta.env.BASE_URL + SITE.resume;
const links = [
  { label: "github", url: SITE.github, primary: true },
  { label: "linkedin", url: SITE.linkedin },
  { label: "resume.pdf", url: resumeHref },
  { label: "email", url: `mailto:${SITE.email}` },
];
---

<section class="hero" id="hero">
  <div class="hero-inner">
    <p class="boot-line mono" id="boot-line" data-text={SITE.bootLine} aria-hidden="true">{SITE.bootLine}</p>
    <h1 id="hero-name">{SITE.name}</h1>
    <p class="hero-tagline" id="hero-tagline">{SITE.tagline}</p>
    <p class="hero-sub mono" id="hero-sub">{SITE.subline}</p>
    <div class="hero-links" id="hero-links">
      {
        links.map((l) =>
          l.url.startsWith("http") ? (
            <a class={"btn" + (l.primary ? " primary" : "")} href={l.url} target="_blank" rel="noopener">
              {l.label}
            </a>
          ) : (
            <a class={"btn" + (l.primary ? " primary" : "")} href={l.url}>
              {l.label}
            </a>
          )
        )
      }
    </div>
    <p class="personal-note mono" id="hero-note">{SITE.heroNote}</p>
  </div>
  <div class="scroll-hint mono" aria-hidden="true">▼ begin traversal</div>
</section>
